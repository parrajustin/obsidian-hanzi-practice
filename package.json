{
  "name": "obsidian-hanzi-practice",
  "version": "1.0.0",
  "description": "Hanzi character practice plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "jest",
    "build:e2e": "esbuild tests/e2e_runner.ts --bundle --platform=node --target=node18 --outfile=tests/e2e_runner.js",
    "test:e2e": "npm run build && npm run build:e2e && node tests/e2e_runner.js",
    "test:e2e:goldens": "npm run build && npm run build:e2e && E2E_REGEN_GOLDENS=1 node tests/e2e_runner.js",
    "test:e2e:docker": "bash docker/build-and-run.sh",
    "test:e2e:docker:goldens": "E2E_REGEN_GOLDENS=1 bash docker/build-and-run.sh node tests/e2e_runner.js"
  },
  "dependencies": {
    "hanzi-writer": "^3.5.0",
    "standard-obsidian-lib": "file:../standard-obsidian-lib",
    "standard-ts-lib": "file:../standard-ts-lib",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@swc/core": "^1.3.100",
    "@swc/jest": "^0.2.29",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.19.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "obsidian": "latest",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^22.0.0",
    "ts-jest": "^29.1.1",
    "tslib": "2.6.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@swc/core"
    ]
  }
}
